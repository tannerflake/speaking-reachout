# ---------------------------------------------------------------------------
# Speaker Outreach CRM — environment variables
# Copy to `.env.local` and fill in. NEVER commit real secrets.
# ---------------------------------------------------------------------------

# Supabase ------------------------------------------------------------------
# Project URL + anon key are safe for the browser (NEXT_PUBLIC_).
# The service-role key is server-only and bypasses RLS — keep it secret.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Claude --------------------------------------------------------------------
ANTHROPIC_API_KEY=

# Gmail OAuth ---------------------------------------------------------------
# From Google Cloud Console → APIs & Services → Credentials (OAuth client ID,
# type "Web application"). The redirect URI must EXACTLY match what you
# register there, e.g. http://localhost:3000/api/gmail/callback for local dev
# or https://your-app.vercel.app/api/gmail/callback in production.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# Optional contact-resolution provider (swappable) --------------------------
# claude (default) | hunter | apollo
CONTACT_RESOLVER=claude
HUNTER_API_KEY=
APOLLO_API_KEY=

# App ------------------------------------------------------------------------
# Used to build absolute URLs (Gmail OAuth redirect fallback). Optional.
NEXT_PUBLIC_APP_URL=http://localhost:3000
